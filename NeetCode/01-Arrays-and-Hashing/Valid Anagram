class Solution:
    def isAnagram(self, s: str, t: str) -> bool:
        label1, label2 = {} , {}
        if len(s) != len(t):
            return False
        for i, x in enumerate(s):
            label1[s[i]] = label1.get(s[i],0) + 1 
            label2[t[i]] = label2.get(t[i],0) + 1 
            
        if label1 == label2:
            return True
        else:
            return False
