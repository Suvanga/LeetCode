class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        buy = prices[0]
        maxval = 0
        for i in range(len(prices)):
            for j in range(len(prices)-1, i ,-1):
                maxval = max(prices[j]-prices[i], maxval) 
        return maxval 


