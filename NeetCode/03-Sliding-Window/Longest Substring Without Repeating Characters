class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
         mp = set()
         l= 0
         res = 0

         for i in range(len(s)-1):
            while s[i] in mp:
                mp.remove(s[l])
                l+=1
            mp.add(s[i])
            res = max(res,i-l+1)
         return res
