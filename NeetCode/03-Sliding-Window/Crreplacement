class Solution:
    def characterReplacement(self, s: str, k: int) -> int:
        res = 0
        charSet = set(s)

        for c in charSet:
            count = l = 0
            for r in range(len(s)):
                if s[r] == c:
                    count += 1

                while (r - l + 1) - count > k:
                    if s[l] == c:
                        count -= 1
                    l += 1

                res = max(res, r - l + 1)
        return res

# Time complexity: O(n * m) where n is the length of the string and m is the number of unique characters in the string.

# Example usage:
solution = Solution()
s = "AAABABB"
k = 1
result = solution.characterReplacement(s, k)
print(f"The longest repeating character replacement length for string '{s}' with k={k} is: {result}")
